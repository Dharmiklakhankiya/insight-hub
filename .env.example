# Insight Hub environment configuration

# Runtime mode: development | test | production
NODE_ENV=development

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/insight_hub

# Must be at least 32 characters in production
JWT_SECRET=change_this_development_only_jwt_secret_key_12345

# JSON Web Token lifetime (jsonwebtoken format)
JWT_EXPIRES_IN=15m

# Public base URL for metadata and server-side URL construction
APP_URL=http://localhost:3000